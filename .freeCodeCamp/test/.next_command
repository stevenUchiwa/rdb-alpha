[ -z "${VSCODE_PYTHON_AUTOACTIVATE_GUARD:-}" ]
export VSCODE_PYTHON_AUTOACTIVATE_GUARD=1
[ -n "${VSCODE_PYTHON_BASH_ACTIVATE:-}" ]
for var in "${!VSCODE_PYTHON_@}"
case "$var" in
__vsc_regex_environment="^CYGWIN*|MINGW*|MSYS*"
[[ "$(uname -s)" =~ $__vsc_regex_environment ]]
__vsc_is_windows=0
__vsc_regex_histcontrol=".*(erasedups|ignoreboth|ignoredups|ignorespace).*"
[[ "${HISTCONTROL:-}" =~ $__vsc_regex_histcontrol ]]
__vsc_history_verify=1
builtin unset __vsc_regex_environment
builtin unset __vsc_regex_histcontrol
__vsc_initialized=0
__vsc_original_PS1="$PS1"
__vsc_original_PS2="$PS2"
__vsc_custom_PS1=""
__vsc_custom_PS2=""
__vsc_in_command_execution="1"
__vsc_current_command=""
__vsc_nonce="$VSCODE_NONCE"
unset VSCODE_NONCE
__vsc_stable="$VSCODE_STABLE"
unset VSCODE_STABLE
[ "$__vsc_stable" = "0" ]
[ -n "$STARSHIP_SESSION_KEY" ]
[ -n "$POSH_SESSION_ID" ]
builtin printf '\e]633;P;HasRichCommandDetection=True\a'
[[ -n "${bash_preexec_imported:-}" ]]
__vsc_dbg_trap="$(__vsc_get_trap DEBUG)"
[[ -z "$__vsc_dbg_trap" ]]
[[ "$__vsc_dbg_trap" != '__vsc_preexec "$_"' && "$__vsc_dbg_trap" != '__vsc_preexec_all "$_"' ]]
trap '__vsc_preexec_all "$_"' DEBUG
__vsc_original_prompt_command=${PROMPT_COMMAND:-}
declare -p RANDOM
echo RANDOM % 75
echo $(RANDOM % 75)
echo $(( RANDOM % 75 ))
echo $(( RANDOM % 75 + 1 ))
./bingo.sh
./bingo.sh
./bingo.sh
help let
./bingo.sh
help test
help if
help test
clear
./bingo.sh
./bingo.sh
touch fortune.sh
chmod +x fortune.sh
./fortune.sh
ARR=("a" "b" "c")
echo ${ARR[1]}
echo $@
echo ${ARR@}
echo ${ARR[@]}
declare -p
declare -p ARR
./fortune.sh
help
help function
./fortune.sh
./fortune.sh
help
help until
help test
./fortune.sh
help [[ expression ]]
